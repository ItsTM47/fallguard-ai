# Frontend (Vite)
VITE_LINE_WEBHOOK_URL=http://localhost:8787/line-webhook
# Optional: must match LINE_RELAY_SECRET if set
VITE_LINE_RELAY_SECRET=

# Relay server
LINE_RELAY_PORT=8787
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_TARGET_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional but recommended
LINE_RELAY_SECRET=

# Optional (required if you want LINE image message)
# Example: https://your-subdomain.ngrok-free.app
LINE_PUBLIC_BASE_URL=
# Optional static ngrok domain for `npm run dev:all`
# Example: your-subdomain.ngrok-free.app
NGROK_DOMAIN=
# Optional storage path for uploaded snapshots
LINE_IMAGE_STORAGE_DIR=backend/uploads
# Optional max webhook payload bytes (base64 image can be large)
LINE_MAX_BODY_BYTES=8000000
# Auto cleanup: delete images older than N hours (0 = disable age cleanup)
LINE_IMAGE_RETENTION_HOURS=24
# Auto cleanup interval in seconds (0 = disable periodic cleanup)
LINE_IMAGE_CLEANUP_INTERVAL_SECONDS=300
# Keep at most N newest images (0 = disable max-files cleanup)
LINE_IMAGE_MAX_FILES=500

# Optional MLflow tracking
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=fallguard-alerts
# Optional: upload incoming webhook image to MLflow artifact storage
MLFLOW_LOG_IMAGE_ARTIFACT=false
# Artifact subfolder inside each run
MLFLOW_IMAGE_ARTIFACT_PATH=event-images
# Max image size in bytes for artifact upload (0 = no limit)
MLFLOW_IMAGE_ARTIFACT_MAX_BYTES=2000000
# Optional auth (choose either token or username/password)
MLFLOW_TRACKING_TOKEN=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
# Docker MLflow backend store (default sqlite to avoid creating many tables in app Postgres)
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
# Number of API workers (use 1 on small VMs to reduce crashes/OOM)
MLFLOW_WORKERS=1
# For debugging only. true = disable host/CORS security checks in MLflow
MLFLOW_DISABLE_SECURITY_MIDDLEWARE=false
# MLflow UI/API security middleware (set strict values in production)
MLFLOW_ALLOWED_HOSTS=*
MLFLOW_CORS_ALLOWED_ORIGINS=*

# Optional real LLM analytics (relay backend)
# Frontend should set:
#   VITE_LLM_ANALYTICS_ENABLED=true
#   VITE_LLM_ANALYTICS_URL=http://localhost:8787/analytics/insight
LLM_ANALYTICS_ENABLED=false
# OpenAI-compatible API key (server-side only)
LLM_API_KEY=
# Optional OpenAI-compatible endpoint and model
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Timezone for hourly/day analytics (IANA name)
LLM_TIMEZONE=Asia/Bangkok
# Request timeout (ms) and max events sent to LLM prompt
LLM_TIMEOUT_MS=20000
LLM_MAX_INPUT_EVENTS=240

# Postgres (relay event store)
DATABASE_ENABLED=true
DATABASE_URL=postgresql://fallguard:fallguard@localhost:5432/fallguard
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# Docker-only Postgres connection (relay container -> postgres service)
DOCKER_DATABASE_URL=postgresql://fallguard:fallguard@postgres:5432/fallguard
POSTGRES_DB=fallguard
POSTGRES_USER=fallguard
POSTGRES_PASSWORD=fallguard
POSTGRES_PORT=5432

# pgAdmin (local DB GUI)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# Optional run metadata
RELAY_APP_VERSION=dev
RELAY_GIT_SHA=

# ngrok
NGROK_AUTHTOKEN=YOUR_REAL_AUTHTOKEN
NGROK_DOMAIN=your-subdomain.ngrok-free.app   # ถ้ามี static domain
LINE_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
